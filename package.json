{
  "name": "ifvisible.js",
  "version": "3.0.0",
  "description": "Crossbrowser & lightweight way to check if user is looking at the page or interacting with it. (wrapper around the HTML5 Page Visibility API)",
  "type": "module",
  "main": "./dist/ifvisible.cjs",
  "module": "./dist/ifvisible.js",
  "types": "./dist/ifvisible.d.ts",
  "unpkg": "./dist/ifvisible.global.js",
  "jsdelivr": "./dist/ifvisible.global.js",
  "exports": {
    ".": {
      "types": "./dist/ifvisible.d.ts",
      "import": "./dist/ifvisible.js",
      "require": "./dist/ifvisible.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:demo": "tsup && cp dist/ifvisible.js docs/ifvisible.js && cp dist/ifvisible.js.map docs/ifvisible.js.map",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "release": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/serkanyersen/ifvisible.js.git"
  },
  "keywords": [
    "visibility",
    "HTML5",
    "cross",
    "browser",
    "api",
    "UI",
    "idle",
    "status",
    "mousemove",
    "reading",
    "mode",
    "tab",
    "change",
    "typescript",
    "page-visibility",
    "page-lifecycle"
  ],
  "author": "Serkan Yersen <serkanyersen@gmail.com> (http://serkan.io/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/serkanyersen/ifvisible.js/issues"
  },
  "homepage": "https://github.com/serkanyersen/ifvisible.js",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "latest",
    "eslint": "latest",
    "jsdom": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
